generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  BROKER
  LANDLORD
  CUSTOMER
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DealStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  password      String?   // Nullable: OAuth users have no password
  role          Role      @default(CUSTOMER)
  setupComplete Boolean   @default(false) // true sau khi user chọn role (OAuth) hoặc đăng ký thủ công
  avatar        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  properties    Property[]   @relation("LandlordProperties")
  brokerDeals   Deal[]       @relation("BrokerDeals")
  customerDeals Deal[]       @relation("CustomerDeals")
  shareLinks    ShareLink[]
  sentInquiries   RoomInquiry[] @relation("BrokerInquiries")
  notifications   Notification[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id            String     @id @default(cuid())
  name          String
  description   String?
  phone         String?
  email         String?
  address       String?
  logo          String?
  zaloGroupLink String?    // link nhóm Zalo của hệ thống
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  properties    Property[]

  @@map("companies")
}

model Property {
  id            String         @id @default(cuid())
  companyId     String?
  landlordId    String
  name          String
  description   String?
  fullAddress   String
  district      String
  streetName    String
  city          String         @default("Hà Nội")
  latitude      Float?
  longitude     Float?
  totalFloors   Int            @default(1)
  totalRooms    Int            @default(0)
  amenities     String[]       @default([])
  images        String[]       @default([])
  status        PropertyStatus @default(PENDING)
  isActive      Boolean        @default(true)
  // NEW fields
  zaloPhone     String?        // SĐT Zalo chủ nhà (tạo link zalo)
  landlordNotes String?        // Lưu ý của chủ nhà cho MG
  parkingCar    Boolean        @default(false)  // Ô tô đỗ cửa
  parkingBike   Boolean        @default(true)   // Để xe máy/xe đạp
  evCharging    Boolean        @default(false)  // Sạc xe điện
  petAllowed    Boolean        @default(false)  // Nuôi thú cưng
  foreignerOk   Boolean        @default(false)  // Cho người nước ngoài thuê
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  company       Company?       @relation(fields: [companyId], references: [id])
  landlord      User           @relation("LandlordProperties", fields: [landlordId], references: [id])
  roomTypes     RoomType[]

  @@index([landlordId])
  @@index([companyId])
  @@index([district])
  @@index([status])
  @@index([status, district])
  @@map("properties")
}

model RoomType {
  id                  String    @id @default(cuid())
  propertyId          String
  name                String    // "Loại 1 - Phòng đơn", "Loại 2 - Studio"...
  typeName            String    @default("don") // don, gac_xep, 1k1n, 2k1n, studio, duplex
  areaSqm             Float
  priceMonthly        Float
  deposit             Float?    // mặc định = priceMonthly (1 tháng tiền thuê)
  description         String?
  amenities           String[]  @default([])
  images              String[]  @default([])
  videos              String[]  @default([])  // URL video từ Supabase Storage (tối đa 3)

  // Quản lý số lượng theo loại
  totalUnits          Int       @default(1)    // tổng số phòng loại này
  availableUnits      Int       @default(1)    // số phòng đang trống
  availableRoomNames  String?                  // "101, 201, 301" — tên cụ thể phòng trống
  isAvailable         Boolean   @default(true) // bật/tắt nhanh toàn bộ loại này
  isApproved          Boolean   @default(false)

  // Chính sách hoa hồng & cho thuê
  commissionJson      String?   // {"6":40, "12":50} = 6 tháng 40%, 12 tháng 50%
  shortTermAllowed    Boolean   @default(false) // cho thuê ngắn hạn?
  shortTermMonths     String?   // "1,2,3" — số tháng ngắn hạn cho phép
  shortTermPrice      Float?    // giá thuê ngắn hạn/tháng

  landlordNotes       String?   // lưu ý cho MG
  viewCount           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  deals               Deal[]
  shareLinks          ShareLink[]
  inquiries           RoomInquiry[]

  @@index([propertyId])
  @@index([isAvailable])
  @@index([isApproved])
  @@index([priceMonthly])
  @@index([typeName])
  @@index([isAvailable, isApproved, priceMonthly])
  @@map("room_types")
}

model Deal {
  id                String     @id @default(cuid())
  roomTypeId        String
  brokerId          String
  customerId        String?
  customerName      String?
  customerPhone     String?
  dealPrice         Float
  commissionTotal   Float      @default(0)
  commissionBroker  Float      @default(0)
  commissionCompany Float      @default(0)
  commissionRate    Float      @default(100)
  notes             String?
  status            DealStatus @default(PENDING)
  dealDate          DateTime   @default(now())
  confirmedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  roomType          RoomType   @relation(fields: [roomTypeId], references: [id])
  broker            User       @relation("BrokerDeals", fields: [brokerId], references: [id])
  customer          User?      @relation("CustomerDeals", fields: [customerId], references: [id])

  @@index([brokerId])
  @@index([roomTypeId])
  @@index([status])
  @@index([createdAt])
  @@map("deals")
}

model ShareLink {
  id          String    @id @default(cuid())
  roomTypeId  String?   // null khi isSystem = true
  brokerId    String
  token       String    @unique
  viewCount   Int       @default(0)
  isActive    Boolean   @default(true)
  isSystem    Boolean   @default(false) // true = link tổng chủ nhà (tất cả phòng trống)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  roomType    RoomType?  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  broker      User       @relation(fields: [brokerId], references: [id])

  @@index([token])
  @@index([brokerId])
  @@index([roomTypeId])
  @@map("share_links")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

model RoomInquiry {
  id          String    @id @default(cuid())
  roomTypeId  String
  brokerId    String
  message     String    @default("Còn phòng không?")
  reply       String?   // "CÒN" / "HẾT" / custom message
  repliedAt   DateTime?
  createdAt   DateTime  @default(now())

  roomType    RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  broker      User      @relation("BrokerInquiries", fields: [brokerId], references: [id])

  @@index([roomTypeId])
  @@index([brokerId])
  @@map("room_inquiries")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "inquiry", "deal", "approval", "reply"
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
