{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx next:*)",
      "Bash(npx prisma:*)",
      "Bash(powershell -Command \"Stop-Process -Name node -Force -ErrorAction SilentlyContinue\")",
      "Bash(powershell -Command \"Stop-Process -Name node -Force -ErrorAction SilentlyContinue; Stop-Process -Name next-server -Force -ErrorAction SilentlyContinue\")",
      "Bash(npm run:*)",
      "Bash(./node_modules/.bin/prisma generate:*)",
      "Bash(tasklist)",
      "Bash(taskkill //F //IM node.exe)",
      "Bash(npx tsx:*)",
      "Bash(npx tsc:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)",
      "Bash(xargs cat:*)",
      "Bash(node -e \"require\\('zod'\\)\")",
      "Bash(echo \"EXIT=$?\")",
      "Bash(echo \"EXIT_CODE=$?\")",
      "Bash(git check-ignore *)",
      "Bash(git commit -m ' *)",
      "Bash(git remote *)",
      "Bash(git fetch *)"
    ]
  }
}
